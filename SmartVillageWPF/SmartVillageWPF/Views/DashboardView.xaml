<UserControl x:Class="SmartVillageWPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartVillageWPF.ViewModels"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <!-- Header -->
            <TextBlock Style="{StaticResource HeadlineStyle}">
                <Run Text="Dashboard" />
                <Run Text=" – " Foreground="{StaticResource OnSurfaceVariantBrush}" />
                <Run Text="{Binding VillageName, Mode=OneWay, FallbackValue='Select a village'}"
                     Foreground="{StaticResource OnSurfaceVariantBrush}" />
            </TextBlock>

            <!-- Summary Cards -->
            <UniformGrid Columns="3" Margin="0,0,0,16">
                <!-- Active Sensors Card -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="ACTIVE SENSORS" Style="{StaticResource CaptionStyle}"
                                   FontSize="13" />
                        <TextBlock Text="{Binding ActiveSensorCount}" FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Total Readings Card -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="6,0,6,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL READINGS" Style="{StaticResource CaptionStyle}"
                                   FontSize="13" />
                        <TextBlock Text="{Binding TotalReadings}" FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Discovered Devices Card -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="DEVICES" Style="{StaticResource CaptionStyle}"
                                   FontSize="13" />
                        <TextBlock Text="{Binding DiscoveredDeviceCount}" FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Feature status indicators -->
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Village Features" Style="{StaticResource TitleStyle}" Margin="0,0,0,8" />
                    <WrapPanel>
                        <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#E0E0E0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSensorDataEnabled}" Value="True">
                                            <Setter Property="Background" Value="#C8E6C9" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="📡 Sensor Data" FontSize="12" />
                        </Border>
                        <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#E0E0E0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWeatherEnabled}" Value="True">
                                            <Setter Property="Background" Value="#C8E6C9" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="🌤 Weather" FontSize="12" />
                        </Border>
                        <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#E0E0E0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMessagesEnabled}" Value="True">
                                            <Setter Property="Background" Value="#C8E6C9" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="💬 Messages" FontSize="12" />
                        </Border>
                        <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#E0E0E0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEventsEnabled}" Value="True">
                                            <Setter Property="Background" Value="#C8E6C9" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="📅 Events" FontSize="12" />
                        </Border>
                        <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#E0E0E0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMapEnabled}" Value="True">
                                            <Setter Property="Background" Value="#C8E6C9" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="🗺 Map" FontSize="12" />
                        </Border>
                        <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#E0E0E0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRideShareEnabled}" Value="True">
                                            <Setter Property="Background" Value="#C8E6C9" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="🚗 Ride Share" FontSize="12" />
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Discovered Devices List -->
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12"
                    Visibility="{Binding DiscoveredDevices.Count, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Collapsed}">
                <StackPanel>
                    <TextBlock Text="Discovered Devices" Style="{StaticResource TitleStyle}" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding DiscoveredDevices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource StatusOkBrush}" Margin="0,0,8,0"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding}" Style="{StaticResource BodyStyle}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Sensor Readings (only when sensor data is enabled) -->
            <Border Margin="0,0,0,12">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSensorDataEnabled}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Recent Sensor Readings" Style="{StaticResource TitleStyle}" Margin="0,0,0,8" />
                    <ListView ItemsSource="{Binding RecentReadings}" MaxHeight="400"
                              BorderThickness="0" Background="Transparent">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Sensor ID" Width="80"
                                                DisplayMemberBinding="{Binding SensorId}" />
                                <GridViewColumn Header="Value" Width="100"
                                                DisplayMemberBinding="{Binding Value, StringFormat='{}{0:F2}'}" />
                                <GridViewColumn Header="Unit" Width="70"
                                                DisplayMemberBinding="{Binding Unit}" />
                                <GridViewColumn Header="Status" Width="80"
                                                DisplayMemberBinding="{Binding Status}" />
                                <GridViewColumn Header="Timestamp" Width="200"
                                                DisplayMemberBinding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Messages (only when messages feature is enabled) -->
            <Border Margin="0,0,0,12">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMessagesEnabled}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Messages" Style="{StaticResource TitleStyle}" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource SurfaceVariantBrush}" BorderThickness="0,0,0,1"
                                        Padding="0,4" Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Text}" Style="{StaticResource BodyStyle}" TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Priority}" Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" />
                                            <TextBlock Text=" – " Style="{StaticResource CaptionStyle}" />
                                            <TextBlock Text="{Binding CreatedAt}" Style="{StaticResource CaptionStyle}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No messages available."
                               Style="{StaticResource CaptionStyle}" Margin="0,4"
                               Visibility="{Binding Messages.Count, Converter={StaticResource ZeroToVisibilityConverter}, FallbackValue=Visible}" />
                </StackPanel>
            </Border>

            <!-- Rideshares (only when rideshare feature is enabled) -->
            <Border>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRideShareEnabled}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Rideshare Benches" Style="{StaticResource TitleStyle}" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding Rideshares}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource TitleStyle}" FontSize="15" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Style="{StaticResource BodyStyle}">
                                                <Run Text="👥 " />
                                                <Run Text="{Binding PersonCount, Mode=OneWay}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding MaxCapacity, Mode=OneWay, FallbackValue='–'}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No rideshare benches available."
                               Style="{StaticResource CaptionStyle}" Margin="0,4"
                               Visibility="{Binding Rideshares.Count, Converter={StaticResource ZeroToVisibilityConverter}, FallbackValue=Visible}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
