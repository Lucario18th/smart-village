<Application x:Class="SmartVillageWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:SmartVillageWPF.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Value Converters -->
            <views:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter" />
            <views:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
            <views:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
