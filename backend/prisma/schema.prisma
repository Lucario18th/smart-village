datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// Rollen für Nutzer im Dorf / Account
enum UserRole {
  ADMIN      // darf alles, inkl. Sensor-Setup, User-Verwaltung
  TECH       // darf Sensoren / Technik konfigurieren
  VIEWER     // darf nur ansehen
}

// Standardisierte Statuswerte
enum SensorHealthStatus {
  OK
  WARN
  ERROR
  UNKNOWN
}

enum ReadingStatus {
  OK
  SUSPECT
  ERROR
}

model Account {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  emailVerified Boolean   @default(false)
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?

  villages     Village[]
}

model Village {
  id           Int       @id @default(autoincrement())
  accountId    Int
  name         String
  locationName String
  phone        String?
  infoText     String?
  contactEmail String?
  contactPhone String?
  municipalityCode String?

  account      Account   @relation(fields: [accountId], references: [id])
  users        User[]
  sensors      Sensor[]
  messages     Message[]
  rideshares   RideShare[]

  @@index([accountId])
}

model User {
  id           Int       @id @default(autoincrement())
  villageId    Int
  email        String    @unique
  passwordHash String
  displayName  String
  phone        String?
  infoText     String?
  role         UserRole  @default(VIEWER)

  village      Village   @relation(fields: [villageId], references: [id])
}

model SensorType {
  id          Int       @id @default(autoincrement())
  name        String
  unit        String
  description String?

  sensors     Sensor[]
}

model Sensor {
  id           Int           @id @default(autoincrement())
  villageId    Int
  sensorTypeId Int
  name         String
  infoText     String?
  isActive     Boolean       @default(true)
  latitude     Float?
  longitude    Float?

  village      Village       @relation(fields: [villageId], references: [id])
  sensorType   SensorType    @relation(fields: [sensorTypeId], references: [id])
  status       SensorStatus?
  readings     SensorReading[]

  @@index([villageId])
}

model SensorStatus {
  id        Int                @id @default(autoincrement())
  sensorId  Int                @unique
  status    SensorHealthStatus @default(UNKNOWN)
  message   String?
  updatedAt DateTime           @default(now())

  sensor    Sensor             @relation(fields: [sensorId], references: [id])
}

model SensorReading {
  id       Int           @id @default(autoincrement())
  sensorId Int
  ts       DateTime
  value    Float
  status   ReadingStatus @default(OK)
  extra    Json?

  sensor   Sensor        @relation(fields: [sensorId], references: [id])

  @@index([sensorId, ts])
  @@index([ts])
}

model Message {
  id        Int       @id @default(autoincrement())
  villageId Int
  text      String
  priority  String    @default("normal")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  village   Village   @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@index([villageId])
  @@index([createdAt])
}

model RideShare {
  id           Int       @id @default(autoincrement())
  villageId    Int
  name         String
  description  String?
  personCount  Int       @default(0)
  maxCapacity  Int?
  status       String    @default("active")
  latitude     Float
  longitude    Float
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  village      Village   @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@index([villageId])
  @@index([status])
}
