datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?

  villages      Village[]
}

model Village {
  id           Int       @id @default(autoincrement())
  accountId    Int
  name         String
  locationName String
  phone        String?
  infoText     String?

  account      Account   @relation(fields: [accountId], references: [id])
  users        User[]
  sensors      Sensor[]
}

model User {
  id           Int       @id @default(autoincrement())
  villageId    Int
  email        String    @unique
  passwordHash String
  displayName  String
  phone        String?
  infoText     String?

  village      Village   @relation(fields: [villageId], references: [id])
}

model SensorType {
  id          Int       @id @default(autoincrement())
  name        String
  unit        String
  description String?

  sensors     Sensor[]
}

model Sensor {
  id           Int          @id @default(autoincrement())
  villageId    Int
  sensorTypeId Int
  name         String
  infoText     String?
  isActive     Boolean      @default(true)

  village      Village      @relation(fields: [villageId], references: [id])
  sensorType   SensorType   @relation(fields: [sensorTypeId], references: [id])
  status       SensorStatus?
  readings     SensorReading[]
}

model SensorStatus {
  id        Int      @id @default(autoincrement())
  sensorId  Int      @unique
  status    String
  message   String?
  updatedAt DateTime @default(now())

  sensor    Sensor   @relation(fields: [sensorId], references: [id])
}

model SensorReading {
  id       Int      @id @default(autoincrement())
  sensorId Int
  ts       DateTime
  value    Float
  status   String?
  extra    Json?

  sensor   Sensor   @relation(fields: [sensorId], references: [id])

  @@index([sensorId, ts])
  @@index([ts])
}
