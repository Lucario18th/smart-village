datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// Rollen für Nutzer im Dorf / Account
enum UserRole {
  ADMIN      // darf alles, inkl. Sensor-Setup, User-Verwaltung
  TECH       // darf Sensoren / Technik konfigurieren
  VIEWER     // darf nur ansehen
}

// Standardisierte Statuswerte
enum SensorHealthStatus {
  OK
  WARN
  ERROR
  UNKNOWN
}

enum ReadingStatus {
  OK
  SUSPECT
  ERROR
}

// Herkunft eines Sensors (klassisch vs. AI-Service)
enum SensorOrigin {
  HARDWARE    // klassischer physischer Sensor
  AI_SERVICE  // z.B. Kamera + AI-Personenerkennung
}

enum AccountType {
  MUNICIPAL
  PRIVATE
}

model Account {
  id                        Int       @id @default(autoincrement())
  email                     String    @unique
  passwordHash              String
  accountType               AccountType @default(MUNICIPAL)
  isPublicAppApiEnabled     Boolean   @default(true)
  isAdmin                   Boolean   @default(false)
  emailVerified             Boolean   @default(false)
  verificationCode          String?
  verificationCodeExpiresAt DateTime?
  createdAt                 DateTime  @default(now())
  lastLoginAt               DateTime?

  villages                  Village[]
}

model Village {
  id               Int       @id @default(autoincrement())
  accountId        Int
  postalCodeId     Int?
  name             String
  locationName     String
  phone            String?
  statusText       String?
  infoText         String?
  contactEmail     String?
  contactPhone     String?
  municipalityCode String?
  postalCode       PostalCode? @relation(fields: [postalCodeId], references: [id])

  account          Account    @relation(fields: [accountId], references: [id])
  users            User[]
  sensors          Sensor[]
  messages         Message[]
  rideshares       RideShare[]
  devices          Device[]
  features         VillageFeatures?
  villageModules   VillageModule[]

  @@index([accountId])
  @@index([postalCodeId])
}

/// Feature-Flags fuer die mobile App pro Gemeinde.
/// Steuert, welche Module in der App fuer diese Gemeinde sichtbar und aktiv sind.
/// Jede Gemeinde hat hoechstens einen VillageFeatures-Eintrag (1:1-Beziehung).
model VillageFeatures {
  id                      Int     @id @default(autoincrement())

  /// Fremdschluessel auf Village (unique = 1:1-Beziehung)
  villageId               Int     @unique

  /// Sensordaten in der App anzeigen (Temperatur, Luftfeuchtigkeit etc.)
  enableSensorData        Boolean @default(true)

  /// Wetterdaten in der App anzeigen
  enableWeather           Boolean @default(true)

  /// Nachrichten der Gemeinde in der App anzeigen
  enableMessages          Boolean @default(true)

  /// Veranstaltungen und Events in der App anzeigen
  enableEvents            Boolean @default(false)

  /// Kartenansicht in der App aktivieren
  enableMap               Boolean @default(true)

  /// Mitfahrbank-Daten in der App anzeigen
  enableRideShare         Boolean @default(true)

  /// Altkleider-Container-Standorte in der App anzeigen
  enableTextileContainers Boolean @default(false)

  /// Sensordetail: Name in der App anzeigen
  showSensorName          Boolean @default(true)

  /// Sensordetail: Typ in der App anzeigen
  showSensorType          Boolean @default(true)

  /// Sensordetail: Beschreibung in der App anzeigen
  showSensorDescription   Boolean @default(true)

  /// Sensordetail: Koordinaten in der App anzeigen
  showSensorCoordinates   Boolean @default(true)

  village                 Village @relation(fields: [villageId], references: [id], onDelete: Cascade)
}

/// Benutzerdefiniertes Modul einer Gemeinde, dem Sensoren zugeordnet werden koennen.
model VillageModule {
  id          Int       @id @default(autoincrement())
  villageId   Int
  name        String
  description String?
  iconKey     String    @default("sensors")
  moduleType  String    @default("Service")
  isEnabled   Boolean   @default(true)
  createdAt   DateTime  @default(now())

  village     Village   @relation(fields: [villageId], references: [id], onDelete: Cascade)
  sensors     Sensor[]  @relation("VillageModuleSensors")

  @@index([villageId])
}

model PostalCode {
  id      Int    @id @default(autoincrement())
  zipCode String @unique
  city    String
  state   String
  lat     Float?
  lng     Float?

  villages Village[]
}

model User {
  id           Int       @id @default(autoincrement())
  villageId    Int
  email        String    @unique
  passwordHash String
  displayName  String
  phone        String?
  infoText     String?
  role         UserRole  @default(VIEWER)

  village      Village   @relation(fields: [villageId], references: [id])
}

model SensorType {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  unit        String
  description String?

  sensors     Sensor[]
}

model Sensor {
  id           Int           @id @default(autoincrement())
  villageId    Int
  deviceId     Int?
  sensorTypeId Int
  name         String
  infoText     String?

  isActive     Boolean       @default(true)
  receiveData  Boolean       @default(true)

  /// Standard: Sensorwerte sind für die App freigegeben.
  exposeToApp  Boolean       @default(true)

  latitude     Float?
  longitude    Float?

  origin       SensorOrigin  @default(HARDWARE)
  aiProvider   String?
  aiModelName  String?
  aiConfigJson Json?

  village      Village       @relation(fields: [villageId], references: [id])
  device       Device?       @relation(fields: [deviceId], references: [id])
  sensorType   SensorType    @relation(fields: [sensorTypeId], references: [id])
  status       SensorStatus?
  readings     SensorReading[]
  villageModules VillageModule[] @relation("VillageModuleSensors")

  @@index([villageId])
  @@index([deviceId])
}


model SensorStatus {
  id        Int                @id @default(autoincrement())
  sensorId  Int                @unique
  status    SensorHealthStatus @default(UNKNOWN)
  message   String?
  updatedAt DateTime           @default(now())

  sensor    Sensor             @relation(fields: [sensorId], references: [id])
}

model SensorReading {
  id       Int           @id @default(autoincrement())
  sensorId Int
  ts       DateTime
  value    Float
  status   ReadingStatus @default(OK)
  extra    Json?

  sensor   Sensor        @relation(fields: [sensorId], references: [id])

  @@index([sensorId, ts])
  @@index([ts])
}

model Message {
  id        Int       @id @default(autoincrement())
  villageId Int
  text      String
  priority  String    @default("normal")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  village   Village   @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@index([villageId])
  @@index([createdAt])
}

model RideShare {
  id           Int       @id @default(autoincrement())
  villageId    Int
  name         String
  description  String?
  personCount  Int       @default(0)
  maxCapacity  Int?
  status       String    @default("active")
  latitude     Float
  longitude    Float
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  village      Village   @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@index([villageId])
  @@index([status])
}

model Device {
  id        Int       @id @default(autoincrement())
  deviceId  String    @unique
  villageId Int
  name      String?
  latitude  Float?
  longitude Float?

  village   Village   @relation(fields: [villageId], references: [id], onDelete: Cascade)
  sensors   Sensor[]

  @@index([villageId])
}
