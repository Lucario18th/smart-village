NODE_ENV=development
PORT=8000

POSTGRES_DB=smartvillage
POSTGRES_USER=smartvillage
POSTGRES_PASSWORD=CHANGEME_POSTGRES_PASSWORD

DATABASE_URL=postgresql://smartvillage:CHANGEME_POSTGRES_PASSWORD@postgres:5432/smartvillage?schema=public

JWT_SECRET=sv_local_2026_JWT_k8Vw3rQ1nL5mP2xY9sH4dT7uC
JWT_EXPIRES_IN=1h
ADMIN_MAX_LOGIN_ATTEMPTS=5
ADMIN_LOCKOUT_TTL=30m
ADMIN_SESSION_TTL=30m

FRONTEND_URL=https://localhost
VITE_MAILHOG_URL=https://localhost:8025

# SMTP / Mailhog defaults
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Smart Village <no-reply@smart-village.local>"

# MQTT / Mosquitto
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PATTERN=sv/+/+/sensors/+
MQTT_DISCOVERY_PATTERN=sv/+/+/config

# Lokaler KI-Assistent (Ollama-kompatibel)
LOCAL_LLM_ENABLED=true
LOCAL_LLM_BASE_URL=http://ollama:11434
LOCAL_LLM_MODEL=llama3.2:1b
LOCAL_LLM_TIMEOUT_MS=12000

# Credentials für die Timetables-API der Deutschen Bahn
DB_CLIENT_ID=CHANGEME_DB_CLIENT_ID
DB_CLIENT_SECRET=CHANGEME_DB_CLIENT_SECRET
