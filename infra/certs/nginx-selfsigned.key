# Private key removed from repository.
# 
# This file path is kept as a placeholder to document that an nginx
# self-signed TLS private key is expected here for local/dev usage.
# 
# Do NOT commit real private keys to source control.
# Instead, generate a key locally on each environment, for example:
# 
#   openssl req -x509 -nodes -days 365 \
#     -newkey rsa:2048 \
#     -keyout infra/certs/nginx-selfsigned.key \
#     -out infra/certs/nginx-selfsigned.crt \
#     -subj "/CN=localhost"
# 
# Ensure infra/certs/nginx-selfsigned.key is listed in .gitignore
# or managed via your secrets mechanism so that it is never
# committed to the repository.

